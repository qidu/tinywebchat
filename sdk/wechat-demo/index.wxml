<!-- wechat-demo/index.wxml -->
<view class="container">
  <!-- Header -->
  <view class="header">
    <text class="title">🤖 TinyWebChat</text>
    <view class="header-right">
      <text class="status" title="{{statusText}}">{{statusIcon}}</text>
      <button wx:if="{{sessionId}}" class="new-session-btn" bindtap="newSession" title="New Session">+</button>
    </view>
  </view>

  <!-- Login Page -->
  <view wx:if="{{!sessionId}}" class="login">
    <button class="start-btn" bindtap="startChat">Start Chat</button>
  </view>

  <!-- Chat Page -->
  <view wx:else class="chat">
    <scroll-view scroll-y class="messages" scroll-into-view="msg-{{messages.length-1}}">
      <block wx:for="{{messages}}" wx:key="index">
        <view id="msg-{{index}}" class="message {{item.role}} {{item.isPending ? 'pending' : ''}}">
          <view class="bubble">{{item.content}}</view>
        </view>
      </block>
      <view wx:if="{{isTyping}}" class="typing">Assistant is typing...</view>
    </scroll-view>

    <view class="input-area">
      <textarea 
        class="msg-input"
        value="{{inputValue}}" 
        placeholder="Type a message..." 
        bindinput="onInput"
        bindconfirm="sendMessage"
        auto-height
        maxlength="-1"
      />
      <button class="send-btn" bindtap="sendMessage" disabled="{{!inputValue || !sessionId}}">➤</button>
    </view>
  </view>
</view>
