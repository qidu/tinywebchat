/* wechat-demo/index.wxss */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* Login */
.login {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login button {
  background: #0066cc;
  color: white;
  padding: 14px 28px;
  border: none;
  border-radius: 8px;
}

/* Chat */
.chat {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.messages {
  flex: 1;
  padding: 16rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #0066cc;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.message.user .avatar {
  background: #28a745;
}

.bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  background: white;
  margin: 0 16rpx;
  font-size: 28rpx;
}

.message.user .bubble {
  background: #0066cc;
  color: white;
}

.typing {
  padding: 16rpx;
  font-size: 24rpx;
  color: #999;
}

/* Input */
.input-area {
  padding: 16rpx;
  background: white;
  border-top: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-area input {
  flex: 1;
  padding: 16rpx 24rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.input-area button {
  background: #0066cc;
  color: white;
  padding: 16rpx 32rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}
