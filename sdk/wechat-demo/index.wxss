/* wechat-demo/index.wxss */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* Header - Light daytime style */
.header {
  background: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e0e0e0;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.05);
}

.title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status {
  font-size: 32rpx;
}

.new-session-btn {
  background: #f0f0f0 !important;
  color: #333 !important;
  border: 1rpx solid #ddd !important;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 8rpx 20rpx;
  line-height: 1.2;
  margin: 0;
}

/* Login */
.login {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-btn {
  background: #25d366;
  color: white;
  padding: 28rpx 56rpx;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 211, 102, 0.3);
}

/* Chat */
.chat {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.messages {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
  max-width: 80%;
}

.message.user {
  align-self: flex-end;
  margin-left: auto;
}

.bubble {
  padding: 20rpx 28rpx;
  border-radius: 36rpx;
  background: #f0f0f0;
  color: #333;
  font-size: 28rpx;
  line-height: 1.4;
  word-break: break-word;
}

.message.user .bubble {
  background: #dcf8c6;
  color: #333;
}

/* Pending message with blinking dots */
.message.pending .bubble {
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0.3; }
}

.typing {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  color: #666;
}

/* Input */
.input-area {
  padding: 24rpx;
  background: white;
  border-top: 1rpx solid #e0e0e0;
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.msg-input {
  flex: 1;
  padding: 20rpx 28rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  min-height: 80rpx;
  max-height: 400rpx;
}

.msg-input:focus {
  border-color: #25d366;
}

.send-btn {
  width: 88rpx;
  height: 88rpx;
  background: #25d366;
  color: white;
  border: none;
  border-radius: 50%;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.send-btn[disabled] {
  background: #ccc;
}
